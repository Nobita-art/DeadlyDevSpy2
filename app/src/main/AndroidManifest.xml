<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ═══════════ NETWORK ═══════════ -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />

    <!-- ═══════════ BOOT / AUTOSTART ═══════════ -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- OEM Autostart Permissions -->
    <!-- Xiaomi / MIUI -->
    <uses-permission android:name="com.miui.securitycenter.permission.AUTOSTART"
        tools:ignore="ProtectedPermissions" />
    <!-- Huawei -->
    <uses-permission android:name="com.huawei.permission.external_app_settings.USE_COMPONENT"
        tools:ignore="ProtectedPermissions" />
    <!-- Oppo / Realme / OnePlus (ColorOS) -->
    <uses-permission android:name="com.coloros.safecenter.permission.AUTOSTART"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="com.oppo.launcher.permission.READ_SETTINGS"
        tools:ignore="ProtectedPermissions" />
    <!-- Vivo (FuntouchOS) -->
    <uses-permission android:name="com.vivo.notification.permission.AUTOSTART"
        tools:ignore="ProtectedPermissions" />
    <!-- Infinix / Transsion (XOS) -->
    <uses-permission android:name="com.transsion.phonemaster.permission.AUTOSTART"
        tools:ignore="ProtectedPermissions" />
    <!-- Samsung (One UI) -->
    <uses-permission android:name="com.samsung.android.sm.permission.APP_HEALTH"
        tools:ignore="ProtectedPermissions" />
    <!-- Letv / LeEco -->
    <uses-permission android:name="com.letv.android.launcher.permission.AUTOSTART"
        tools:ignore="ProtectedPermissions" />
    <!-- ZTE -->
    <uses-permission android:name="com.zte.permission.AUTOSTART"
        tools:ignore="ProtectedPermissions" />

    <!-- ═══════════ FOREGROUND SERVICE ═══════════ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- ═══════════ BACKGROUND PERSISTENCE ═══════════ -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.REORDER_TASKS" />
    <!-- Overlay: helps some OEM auto-start flows -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- ═══════════ STORAGE ═══════════ -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" tools:ignore="ScopedStorage" />

    <!-- ═══════════ COMMUNICATION ═══════════ -->
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ═══════════ CAMERA ═══════════ -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <!-- ═══════════ LOCATION ═══════════ -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <application
        android:allowBackup="false"
        android:icon="@drawable/mpt"
        android:label="@string/app_name"
        android:roundIcon="@drawable/mpt"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Translucent.NoTitleBar"
        android:usesCleartextTraffic="true"
        tools:targetApi="34">

        <!-- ═══════════ ACTIVITIES ═══════════ -->
        <activity
            android:name=".AppLauncher"
            android:exported="true"
            android:excludeFromRecents="true"
            android:theme="@android:style/Theme.Material.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".WebViewActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:hardwareAccelerated="true"
            android:theme="@android:style/Theme.Material.NoActionBar" />

        <!-- ═══════════ BOOT RECEIVER ═══════════ -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true"
            android:enabled="true"
            android:directBootAware="true">
            <!-- Standard boot intents (highest priority) -->
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.USER_PRESENT" />
                <action android:name="android.intent.action.USER_UNLOCKED" />
            </intent-filter>

            <!-- OEM-specific boot intents -->
            <intent-filter android:priority="1000">
                <!-- HTC / Qualcomm QuickBoot -->
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <!-- Huawei -->
                <action android:name="com.huawei.intent.action.QUICKPOWERON" />
                <!-- Infinix / Transsion XOS -->
                <action android:name="com.transsion.phonemaster.action.BOOT_COMPLETED" />
                <!-- Samsung -->
                <action android:name="com.samsung.android.sm.app.LAUNCH_COMPLETED" />
                <!-- Xiaomi MIUI -->
                <action android:name="com.miui.home.launcher.action.UPDATE_SHORTCUT" />
                <!-- Oppo / ColorOS -->
                <action android:name="com.coloros.safecenter.action.BOOT_COMPLETED" />
                <!-- Vivo FuntouchOS -->
                <action android:name="com.vivo.notification.action.BOOT_COMPLETED" />
                <!-- OnePlus OxygenOS -->
                <action android:name="net.oneplus.launcher.action.BOOT_COMPLETED" />
            </intent-filter>

            <!-- Package replaced (APK update) -->
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.PACKAGE_REPLACED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

        <!-- ═══════════ SERVICE RESTART RECEIVER ═══════════ -->
        <receiver
            android:name=".receiver.ServiceRestartReceiver"
            android:exported="true"
            android:enabled="true"
            android:directBootAware="true">
            <intent-filter android:priority="999">
                <action android:name="com.fasonbot.app.service.CoreService.ALARM" />
                <action android:name="com.fasonbot.app.RESTART_SERVICE" />
            </intent-filter>
        </receiver>

        <!-- ═══════════ NETWORK CHANGE RECEIVER ═══════════ -->
        <receiver
            android:name=".receiver.NetworkReceiver"
            android:exported="true"
            android:enabled="true"
            android:directBootAware="true">
            <intent-filter android:priority="999">
                <action android:name="android.net.conn.CONNECTIVITY_CHANGE" />
                <action android:name="android.net.wifi.WIFI_STATE_CHANGED" />
                <action android:name="android.net.wifi.STATE_CHANGE" />
            </intent-filter>
        </receiver>

        <!-- ═══════════ SMS RECEIVER ═══════════ -->
        <receiver
            android:name=".receiver.SmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- ═══════════ CORE SERVICE ═══════════ -->
        <service
            android:name=".service.CoreService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync|specialUse|camera|location"
            android:stopWithTask="false"
            android:directBootAware="true">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="system_service" />
            <intent-filter>
                <action android:name="com.fasonbot.app.service.CoreService.START" />
                <action android:name="com.fasonbot.app.service.CoreService.RESTART" />
            </intent-filter>
        </service>

        <!-- ═══════════ WATCHDOG JOB SERVICE ═══════════ -->
        <service
            android:name=".service.WatchdogJobService"
            android:permission="android.permission.BIND_JOB_SERVICE"
            android:exported="true"
            android:directBootAware="true" />

        <!-- ═══════════ COMPANION GUARD SERVICE (separate :guard process) ═══════════ -->
        <!-- Dual-process watchdog: if the OS kills the main process, :guard survives  -->
        <!-- and restarts CoreService. The OS almost never kills two processes at once. -->
        <service
            android:name=".service.CompanionService"
            android:process=":guard"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:stopWithTask="false"
            android:directBootAware="true" />

        <!-- ═══════════ DEVICE ADMIN ═══════════ -->
        <receiver
            android:name=".receiver.DeviceAdminReceiver"
            android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
